# Database
DATABASE_URL=postgresql://localhost/ai_company

# GLM API
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4
GLM_TEMPERATURE=0.7

# Image Service
IMAGE_SERVICE=dall_e
OPENAI_API_KEY=your_openai_api_key_here

# API Security
API_KEY_HEADER=

# Environment
ENVIRONMENT=development
DEBUG=true

# WebSocket
WS_HOST=localhost
WS_PORT=8000
