# Database
DATABASE_URL=postgresql://localhost/ai_company

# GLM API
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4
GLM_TEMPERATURE=0.7

# Image Service
IMAGE_SERVICE=dall_e
OPENAI_API_KEY=your_openai_api_key_here

# API Security
API_KEY_HEADER=

# Environment
ENVIRONMENT=development
DEBUG=true

# WebSocket
WS_HOST=localhost
WS_PORT=8000

# OpenClaw Integration (Mac Mini)
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://localhost:4242
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT=180
OPENCLAW_FALLBACK_HOST=

# OpenClaw WebSocket settings
OPENCLAW_WS_ENDPOINT=ws://localhost:18789/
OPENCLAW_WS_PROBE_TIMEOUT=5.0
OPENCLAW_WS_CACHE_TTL=300
OPENCLAW_WS_ENABLED=true
OPENCLAW_REQUESTED_SCOPES=operator.read,operator.write
OPENCLAW_CLIENT_ID=my-ai-company
OPENCLAW_CLIENT_VERSION=local-dev
